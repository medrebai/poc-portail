	measure 'Occupation Rate' = ```
			
			VAR SelectedStartDate =
			    MIN ( 'Dim Date'[day] )
			 
			VAR SelectedEndDate =
			    MAX ( 'Dim Date'[day] )
			 
			-- Active resources in the selected period,
			VAR ActiveResources =
			    CALCULATETABLE (
			        VALUES ( 'Dim Resources'[resource_id] ),
			        FILTER (
			            ALL ( 'Fact Staffing'[day] ),          
			            'Fact Staffing'[day] >= SelectedStartDate
			                && 'Fact Staffing'[day] <= SelectedEndDate
			        )
			    )
			 
			VAR TotalWorkingDaysClient =
			    SUMX (
			        ActiveResources,
			        [Working Days (Client)]
			    )
			 
			VAR TotalWorkingDays =
			    SUMX (
			        ActiveResources,
			       [Working Days]
			    )
			 
			RETURN
			    DIVIDE ( TotalWorkingDaysClient, TotalWorkingDays, 0 )
			 
			```
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: Finance\Occupation Rate
		lineageTag: bc1958e1-926f-46e7-90f1-bbc56d5eea32

