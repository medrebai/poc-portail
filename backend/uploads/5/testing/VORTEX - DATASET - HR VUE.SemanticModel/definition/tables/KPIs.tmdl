	measure 'Working Days (Client)' =
			
			COALESCE(
			    CALCULATE(
			        SUM( 'Fact Sales'[delivery_production_times] ),
			        FILTER( 'Dim Projects', NOT('Dim Projects'[project_typeof_name]) IN {"Projet Interne"})
			    ),
			    0
			)
		displayFolder: HR\Activity
		lineageTag: 92501f19-02dd-413a-aea8-33a14eb43ce7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Working Days (Interne)' =
			
			VAR ResourceSet =
			    VALUES ( 'Dim Resources'[resource_id] )
			RETURN
			SUMX (
			    ResourceSet,
			    VAR WD =
			        CALCULATE ( [Real Working Days] )
			    VAR WDClient =
			        CALCULATE ( [Working Days (Client)] )
			    VAR     WDIntternalProject =
			        CALCULATE ( [Working Days (Internal Proj.)] )
			    VAR Abs =
			        CALCULATE ( [Absences] )
			    VAR InterPerResource =
			        WD - WDClient - WDIntternalProject - Abs
			    RETURN
			        MAX ( 0, InterPerResource )
			)
		displayFolder: HR\Activity
		lineageTag: 9e09907c-1f85-4371-90ee-d488a2bbb8c7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Intercontract Days %' = DIVIDE( [Working Days (Interne)], [Working Days])
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: HR\Activity
		lineageTag: 8777029a-727d-4095-b7d6-c5ff746e2de9

	measure 'Intercontract Resource' =
			
			CALCULATE(
			    DISTINCTCOUNT('Dim Resources'[resource_id]),
