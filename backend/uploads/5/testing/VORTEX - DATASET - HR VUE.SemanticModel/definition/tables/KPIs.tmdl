		lineageTag: 268ec71a-e52d-4ae9-aefe-141db80f9e0b

	measure 'Seniority (in years)' =
			
			VAR selected_window_end = MAX ( 'Dim Date'[Day] )
			RETURN
			AVERAGEX (
			    FILTER (
			        CALCULATETABLE ( 'Fact Contracts', REMOVEFILTERS ( 'Dim Date' ) ),
			        'Fact Contracts'[contract_start_date] <= selected_window_end
			    ),
			    VAR end_count =
			        IF (
			            ISBLANK ( 'Fact Contracts'[contract_end_date] )
			                || 'Fact Contracts'[contract_end_date] >= selected_window_end,
			            selected_window_end,
			            'Fact Contracts'[contract_end_date]
			        )
			    VAR months_count =
			        DATEDIFF ( 'Fact Contracts'[contract_start_date], end_count, MONTH ) + 1
			    RETURN
			        MAX ( 0, DIVIDE ( months_count, 12 ) )
			)
		displayFolder: HR\Info
		lineageTag: 194d3079-fb56-4d7b-9707-45a192476d13

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Seniority levels' =
			
			VAR m = [Seniority (in months)]
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK(m),        "Unknown",
			    m <= 6,            "<6 mois",
			    m <= 12,           "6–12 mois",
			    m <= 24,           "1–2 ans",
			    m <= 36,           "2–3 ans",
			    m <= 48,           "3–4 ans",
			                       ">4 ans"
			)
		displayFolder: HR\Info
		lineageTag: cda008b5-0f57-43b0-9c07-c922a6a65e6a

