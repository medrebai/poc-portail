	measure 'Contract Type Count' =
			
			VAR SelectedStartDate =
			    MIN ( 'Dim Date'[day] )
			
			VAR SelectedEndDate =
			    MAX ( 'Dim Date'[day] )
			
			VAR ActiveResources =
			    CALCULATETABLE (
			        VALUES ( 'Dim Resources'[resource_id] ),
			        FILTER (
			            ALL ( 'Fact Staffing'[day] ),
			            'Fact Staffing'[day] >= SelectedStartDate
			                && 'Fact Staffing'[day] <= SelectedEndDate
			        )
			    )
			
			RETURN
			    CALCULATE (
			        COUNTROWS ( 'Fact Contracts' ),
			        'Fact Contracts'[is_active_contract] = TRUE(),
			        TREATAS ( ActiveResources, 'Dim Resources'[resource_id] )
			    )
		formatString: 0
		displayFolder: HR\Contract
		lineageTag: aacadcd8-ac59-48ef-8ecd-a62688232a2a

	measure 'Contract End Date' =
			
			COALESCE (
			    VAR SelectedStartDate =
			        MIN ( 'Dim Date'[day] )
			
			    VAR SelectedEndDate =
			        MAX ( 'Dim Date'[day] )
			
			    -- Active resources
			    VAR ActiveResources =
			        CALCULATETABLE (
			            VALUES ( 'Dim Resources'[resource_id] ),
			            FILTER (
			                ALL ( 'Fact Staffing'[day] ),
			                'Fact Staffing'[day] >= SelectedStartDate
			                    && 'Fact Staffing'[day] <= SelectedEndDate
			            )
			        )
			
			    VAR CurrentResource =
			        SELECTEDVALUE ( 'Dim Resources'[resource_id] )
			
			    VAR IsResourceActive =
			        CurrentResource IN ActiveResources
			
			    -- Latest contract_start_date among active contracts
			    VAR MaxStartDate =
			        CALCULATE (
			            MAX ( 'Fact Contracts'[contract_start_date] ),
			            'Fact Contracts'[resource_id] = CurrentResource,
			            'Fact Contracts'[is_active_contract] = TRUE ()
			        )
			
			    -- Filter to the single most recent active contract
			    VAR ResourceContracts =
			        CALCULATETABLE (
			            FILTER (
			                'Fact Contracts',
			                'Fact Contracts'[is_active_contract] = TRUE ()
			                    && 'Fact Contracts'[resource_id] = CurrentResource
			                    && 'Fact Contracts'[contract_start_date] = MaxStartDate
			            )
			        )
			
			    -- End date with 2999 fallback
			    VAR LatestEndDateWith2999 =
			        MINX (
			            ResourceContracts,
			            IF (
			                ISBLANK ( 'Fact Contracts'[contract_end_date] ),
			                DATE ( 2999, 1, 1 ),
			                'Fact Contracts'[contract_end_date]
			            )
			        )
			
			    VAR FinalDate =
			        IF ( IsResourceActive, LatestEndDateWith2999 )
			
			    RETURN
			        IF (
			            FinalDate = DATE ( 2999, 1, 1 ) || ISBLANK ( FinalDate ),
			            BLANK (),                              -- will become "undefined"
			            FORMAT ( FinalDate, "dd/MM/yyyy" )     -- display real date
			        ),
			    "undefined"
			)
		displayFolder: HR\Contract
		lineageTag: 9f6a1fd9-ee08-4a96-bb2c-f21d9b9993c9

	measure 'Resource Client Count' =
			
			VAR SelectedStartDate =
