	measure 'Selected General KPI LY' =
			
			VAR KPIName =
			SELECTEDVALUE ( 'General KPIs'[General KPIs Champs] )
			VAR SelectedMeasure =
			SWITCH (
			KPIName,
			"'KPIs'[Revenue]", [Revenue LY],
			"'KPIs'[Payroll]", [Payroll LY],
			"'KPIs'[Margin %]", [Margin % LY],
			"'KPIs'[Payroll / Revenue]", [Payroll / Revenue LY],
			"'KPIs'[Number of HR]", [Active Resources],
			"'KPIs'[Occupation Rate]", [Occupation Rate LY],
			"'KPIs'[Intercontract Cost]", [Intercontract Cost LY],
			"'KPIs'[Turnover %]", [Turnover LY],
			"'KPIs'[Invoice Count]", [Invoice Count LY],
			"'KPIs'[Average Invoice Value (AIV)]", [Average Invoice Value LY],
			"'KPIs'[Number of Projects]", [Projects Count (Interne) LY],
			"'KPIs'[Number of Clients]", [Clients Count LY],
			BLANK ()
			)
			RETURN
			CALCULATE (
			SelectedMeasure,
			SAMEPERIODLASTYEAR ( 'Dim Date'[day] )
			)
		lineageTag: 31f12254-8828-47d1-9d3c-435ec2623e20

