	measure 'Activity Filter' =
			
			VAR segment_start_date =
			    MIN ( 'Dim Date'[day] )
			VAR segment_end_date =
			    MAX ( 'Dim Date'[day] )
			VAR contract_start_date =
			    DATEVALUE ( [Contract Start date] )
			VAR contract_end_date_raw = [Contract End Date]
			VAR contract_end_date =
			    IF (
			        contract_end_date_raw = "undefined",
			        DATE ( 2099, 12, 31 ),
			        DATE ( VALUE ( RIGHT ( contract_end_date_raw, 4 ) ), VALUE ( MID ( contract_end_date_raw, 4, 2 ) ), VALUE ( LEFT ( contract_end_date_raw, 2 ) ) )
			    )
			VAR activity_condition = contract_start_date <= segment_end_date
			    && contract_end_date >= segment_start_date
			    && contract_end_date >= segment_end_date
			RETURN
			    IF ( activity_condition, "Active", "Not Active" )
		displayFolder: HR\Contract
		lineageTag: cd3aa849-5973-477c-95b3-3e35cf5c2c31

