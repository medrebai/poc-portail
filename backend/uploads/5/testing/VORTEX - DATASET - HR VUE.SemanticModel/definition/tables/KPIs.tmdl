	measure Payroll = [Payroll Internal] + [Payroll External]
		formatString: "€"\ #,0.000;-"€"\ #,0.000;"€"\ #,0.000
		displayFolder: Finance\Payroll
		lineageTag: 7218a701-0126-41e5-947c-ed1529e6e997

	measure 'Working Days' =
			
			VAR Region_ = SELECTEDVALUE('Fact Staffing'[agency_id])   -- TN = 1, FR = 2, UAE = 3
			VAR WorkDays =
			    SWITCH (
			        TRUE(),
			        Region_ = 1,
			            CALCULATE (
			                COUNTROWS ( 'Dim Date' ),
			                KEEPFILTERS ( 'Dim Date'[is_weekend] = FALSE() )
			            --    KEEPFILTERS ( 'Dim Date'[is_holiday_TN] = FALSE() )
			            ),
			            Region_ = 2,
			            CALCULATE (
			                COUNTROWS ( 'Dim Date' ),
			                KEEPFILTERS ( 'Dim Date'[is_weekend] = FALSE() )
			            --    KEEPFILTERS ( 'Dim Date'[is_holiday_FR] = FALSE() )
			            ),
			            Region_ = 3,
			            CALCULATE (
			                COUNTROWS ( 'Dim Date' ),
			                KEEPFILTERS ( 'Dim Date'[is_weekend] = FALSE() )
			            --    KEEPFILTERS ( 'Dim Date'[is_holiday_UAE] = FALSE() )
			            ),
			        BLANK()  -- if Region_ is blank or not one of the above
			    )
			RETURN
			COALESCE ( WorkDays, 22 )
		formatString: 0
		displayFolder: HR\Activity
		lineageTag: dd67bbcd-7693-4717-a8f7-b3ab31538aef

	measure 'Intercontract Cost' = ```
			
			VAR SelectedStartDate =
			    MIN ( 'Dim Date'[day] )
			 
			VAR SelectedEndDate =
			    MAX ( 'Dim Date'[day] )
			 
			-- Active resources in the selected period (from Staffing)
			VAR ActiveResources =
			    CALCULATETABLE (
			        DISTINCT ( 'Dim Resources'[resource_id] ),
			        FILTER (
			            ALL ( 'Fact Staffing' ),
			            'Fact Staffing'[day] >= SelectedStartDate
			                && 'Fact Staffing'[day] <= SelectedEndDate
			        )
			    )
			 
			-- Sum cost per resource, then aggregate
			VAR IntercontractCost_Total =
			    SUMX (
			        ActiveResources,
			        VAR ThisResourceID = 'Dim Resources'[resource_id]
			 
			        -- CJM for this resource in the period
			        VAR ResourceCJM =
			            CALCULATE (
			                AVERAGE ( 'Fact Payroll (Internal)'[CJM] ),
			                'Dim Resources'[resource_id] = ThisResourceID,
			                'Fact Payroll (Internal)'[payroll_date] >= SelectedStartDate,
			                'Fact Payroll (Internal)'[payroll_date] <= SelectedEndDate
			            )
			 
			        -- Intercontract working days for this resource in the period
			        VAR ResourceWD_Interne =
			            CALCULATE (
			                [Working Days (Interne)],
			                'Dim Resources'[resource_id] = ThisResourceID,
			                'Fact Staffing'[day] >= SelectedStartDate,
			                'Fact Staffing'[day] <= SelectedEndDate
			            )
			 
			        -- Internal projects cost
			        VAR InternalProjectCost =  
			                CALCULATE(
			                    SUM( 'Fact Costs'[client_ppd_cost] ),
			                    FILTER( 'Dim Projects', ('Dim Projects'[project_typeof_name]) IN {"Projet Interne"})
			                )
			        RETURN
			            ((ResourceWD_Interne * ResourceCJM) + InternalProjectCost
			    ) )
			 
			RETURN
			    COALESCE ( IntercontractCost_Total, 0 )
			 
			```
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Finance\Cost
		lineageTag: 79b34031-a3bf-4783-99ef-c77cd781f011

	measure 'Revenue from Sales' =
			
			COALESCE(
			    CALCULATE(
			        SUM ( 'Fact Sales'[resource_sale] )
			    ),
			    0
			)
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Finance\Sales
		lineageTag: 7295b1bf-0237-4d73-b07f-145de2500346

	measure 'Cost from Sales' =
			
			VAR is_internal_consultant =
			    NOT (SELECTEDVALUE ( 'Fact Costs'[resource_type] ) IN {"Consultant Externe","Consultant Interne P","Conseil Assistance"})
			
			VAR cost_internal_consultant =
			   COALESCE (
			    SUMX (
			        VALUES ( 'Fact Costs'[times_reports_term] ),
			        CALCULATE (
			            AVERAGE ( 'Fact Costs'[resource_cost] ),
			            FILTER (
			                'Dim Projects',
			                NOT ( 'Dim Projects'[project_typeof_name] IN { "Projet Interne" } )
			            )
			        )
			    ),
			    0
			)
			VAR cost_dynamic =
			    COALESCE (
			        CALCULATE (
			            SUM ( 'Fact Costs'[client_ppd_cost] ),
			            FILTER (
			                'Dim Projects',
			                NOT ( 'Dim Projects'[project_typeof_name] IN { "Projet Interne" } )
			            )
			        ),
			        0
			    )
			
			RETURN
			IF (
			    is_internal_consultant,
			    cost_internal_consultant,
			    cost_dynamic
			)
		formatString: "€"\ #,0.00;-"€"\ #,0.00;"€"\ #,0.00
		displayFolder: Finance\Resource
		lineageTag: 095f21c4-ccd9-4233-8028-9755e7b2a1c1

