	partition 'Working Days' = calculated
		mode: import
		source = ```
				
				VAR Months =
				    SUMMARIZE (
				        'Dim Date',
				        'Dim Date'[year],
				        'Dim Date'[month_no],
				        'Dim Date'[year_month], 
				        'Dim Date'[month_name]
				    )
				RETURN
				ADDCOLUMNS (
				    Months,
				    "WD_TN",
				        CALCULATE (
				            COUNTROWS ( 'Dim Date' ),
				            'Dim Date'[is_weekend] = FALSE (),
				            'Dim Date'[is_holiday_TN] = FALSE ()
				        ),
				    "WD_FR",
				        CALCULATE (
				            COUNTROWS ( 'Dim Date' ),
				            'Dim Date'[is_weekend] = FALSE (),
				            'Dim Date'[is_holiday_FR] = FALSE ()
				        ),
				    "WD_UAE",
				        CALCULATE (
				            COUNTROWS ( 'Dim Date' ),
				            'Dim Date'[is_weekend] = FALSE (),
				            'Dim Date'[is_holiday_UAE] = FALSE ()
				        )
				)
				```

	annotation PBI_Id = 976d431b20964cb7b4a2861db75e0a92

